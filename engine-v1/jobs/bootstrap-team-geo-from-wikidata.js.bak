import fs from "fs";
import path from "path";
import { fileURLToPath } from "url";
import { ensureDir, resolveDataPath } from "../storage/data-root.js";
import {
  getLeagueCoverage,
  isContinentalCompetition
} from "../../workers/_shared/leagues-coverage.js";

const WIKIDATA_API_URL = "https://www.wikidata.org/w/api.php";
const DEFAULT_INPUT = resolveDataPath(
  "team-geo",
  "_bootstrap",
  "team-geo.bootstrap.json"
);
const DEFAULT_OUTPUT = resolveDataPath(
  "team-geo",
  "_bootstrap",
  "team-geo.bootstrap.enriched.json"
);

function writeJson(filePath, data) {
  ensureDir(path.dirname(filePath));
  fs.writeFileSync(filePath, JSON.stringify(data, null, 2), "utf8");
}

function readJsonArray(filePath) {
  if (!fs.existsSync(filePath)) return [];
  const raw = fs.readFileSync(filePath, "utf8");
  const parsed = JSON.parse(raw);
  return Array.isArray(parsed) ? parsed : [];
}

function repairTextEncoding(value) {
  return String(value ?? "")
    // Common UTF-8 mojibake rendered through Greek/Windows codepage.
    .replace(/Γ±/g, "ñ")
    .replace(/Γ­/g, "í")
    .replace(/Γ©/g, "é")
    .replace(/Γ¡/g, "á")
    .replace(/Γ³/g, "ó")
    .replace(/Γº/g, "ú")
    .replace(/Γ¼/g, "ü")
    .replace(/Γ£/g, "ã")
    .replace(/Γ§/g, "ç")
    .replace(/Γ¨/g, "è")
    .replace(/Γª/g, "ê")
    .replace(/Γ´/g, "ô")
    .replace(/Γ¯/g, "ï")

    // Common UTF-8 mojibake rendered as Ã sequences.
    .replace(/Ã±/g, "ñ")
    .replace(/Ã­/g, "í")
    .replace(/Ã©/g, "é")
    .replace(/Ã¡/g, "á")
    .replace(/Ã³/g, "ó")
    .replace(/Ãº/g, "ú")
    .replace(/Ã¼/g, "ü")
    .replace(/Ã£/g, "ã")
    .replace(/Ã§/g, "ç")
    .replace(/Ã¨/g, "è")
    .replace(/Ãª/g, "ê")
    .replace(/Ã´/g, "ô")
    .replace(/Ã¯/g, "ï");
}

function normalizeText(value) {
  return repairTextEncoding(value)
    .trim()
    .replace(/\s+/g, " ");
}

function normalizeCountry(value) {
  return normalizeText(value).toLowerCase();
}

function isValidLatitude(value) {
  const n = Number(value);
  return Number.isFinite(n) && n >= -90 && n <= 90 && n !== 0;
}

function isValidLongitude(value) {
  const n = Number(value);
  return Number.isFinite(n) && n >= -180 && n <= 180 && n !== 0;
}

