    if(!document.cookie.match(/^(.*;)?\s*OptanonAlertBoxClosed\s*=\s*[^;]+(.*)?$/) && !window.localStorage.getItem("onetrust_placeholder")){
        document.getElementsByClassName("otPlaceholder")[0].classList.remove("otPlaceholder--hidden");
