		function otAfterCallback() {
		    window.setTimeout(() => {
		        try {
		            if (!window.hasOTAfterCallbackProceeded) {
		                dataLayer.push({event:'gdpr_consent',user_consent:'agree'});
		                document.dispatchEvent(new Event('onetrust'));
