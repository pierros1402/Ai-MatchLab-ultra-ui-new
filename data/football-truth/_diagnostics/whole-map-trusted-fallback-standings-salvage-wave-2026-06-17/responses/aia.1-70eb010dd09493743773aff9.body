		                    otCallback();
		                    if (e.eventStatus === 'useractioncomplete' || e.eventStatus === 'tcloaded') {
		                        otAfterCallback();
		                    };
		                };
		            });
		        } else if (typeof OneTrust === "object") {
		            otCallback();
		            if (!OneTrust.IsAlertBoxClosed()) {
		                OneTrust.OnConsentChanged(() => otAfterCallback());
		            }
		        } else {
		            otCallback();
		        }
		    } catch(e) {
		        console.error(e);
		    }
		};
            // ]]>
        </script>
        
    </head>
