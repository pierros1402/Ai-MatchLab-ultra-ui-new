            if (geoIp === "DE") {
                handleCountryLegalClassNames(geoIp);
            } else {
                document.querySelectorAll(".gambling--" + "DE").forEach((element) => {
                    element.classList.add("gambling--noReservedSpace");
                });
            }
        });

        bocReviveWrapper && mo.observe(bocReviveWrapper, { childList: true});
