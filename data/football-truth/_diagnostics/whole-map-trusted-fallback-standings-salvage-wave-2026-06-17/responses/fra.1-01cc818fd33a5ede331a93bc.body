<script>
	var espn = espn || {};
	espn.isOneSite = false;
	espn.build = "0.778.3";
	espn.siteType = "full";
	espn.anonymous_favorites = "true" === "true";
	espn.isFantasycast = false;
	
	espn.absoluteNavLinks = false;
