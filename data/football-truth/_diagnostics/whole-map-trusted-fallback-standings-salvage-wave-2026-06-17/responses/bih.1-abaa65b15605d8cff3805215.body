            });
        },
        sendConsentInfo: function (optanonActiveGroups, cX) {
            const activeGroups = optanonActiveGroups.split(",").filter(Boolean);
            const usersConsent = {
                pv: this.checkConsentGroups(activeGroups, this.consentRequiredGroups.pv),
                segment: this.checkConsentGroups(activeGroups, this.consentRequiredGroups.segment),
            };

            if (this.alreadySentConsent) {
                cX.callQueue.push([
                    'setConsent',
                    usersConsent,
                    (usersConsent.pv || usersConsent.segment) ? {'runCallQueue': true} : {},
                ]);
            } else {
                cX.callQueue.push([
                    'setConsent',
                    usersConsent,
                ]);
            }

            this.alreadySentConsent = true;
        },
        satiReady: function() {
            // consent info
            if (window.OptanonActiveGroups) {
                this.sendConsentInfo(window.OptanonActiveGroups, window.cX);
            } else {
                document.addEventListener('oneTrustLoaded', () => {
                    this.sendConsentInfo(window.OptanonActiveGroups, window.cX);
                });
            }

            // adblock info
            if (window.bannerHandler) {
                this.sendAdblockInfo(window.bannerHandler, window.cX);
            } else {
                window.addEventListener('bannerHandlerInit', (event) => {
                    this.sendAdblockInfo(event.detail.bannerHandler, window.cX);
                });
            }
        },
    };

