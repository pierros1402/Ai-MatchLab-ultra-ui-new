            segment: ['C0001', 'C0004', 'V2STACK42'], // IAB2V2_9 (child of V2STACK42)
        },
        checkConsentGroups: function (current, needed) {
            return needed.every(item => current.includes(item));
        },
        alreadySentConsent: false,
        sendAdblockInfo: function (bannerHandler, cX) {
            bannerHandler.isAdblockEnabled().then((isAdblockEnabled) => {
                cX.setEventAttributes({'origin': 'brt-adblock', 'persistedQueryId': "fcadb0c22bec63a3e94af5a65644fc6b869880e0"});
