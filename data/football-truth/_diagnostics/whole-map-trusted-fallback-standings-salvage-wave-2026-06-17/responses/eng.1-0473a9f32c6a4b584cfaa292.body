        document.addEventListener('DOMContentLoaded', () => {
            try
            {
                var cb = function() {
                    _cjs.Api.loader.get('onetrust').call(() => {
                        _cjs.Api.loader.get('boxContentManager').call(function(boxContentManager) {
                            boxContentManager.show(
                                _cjs.geoIP,
                                _cjs.geoIPIsoSubdivisionCode0,
