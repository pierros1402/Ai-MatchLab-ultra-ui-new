                                _cjs.Api.config.get('app', 'legal_age_confirmation', 'enabled'),
                                _cjs.Api.config.get('app', 'legal_age_confirmation', 'geoip')
                            );
                        });
                    });
                    document.displayTrustedAdvert();
                };
                _cjs.Api.loader.get('geoIpResolver').call(cb);
            }
            catch(e)
            {
            }
        });
    });
</script>
